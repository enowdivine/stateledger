{
  "name": "stateledger",
  "version": "0.0.0",
  "private": true,
  "description": "Database-backed state machine for Node and TypeScript — transitions persisted, audited, concurrency-safe.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Enow Divine",
    "email": "sirdivine16@gmail.com",
    "url": "https://github.com/enowdivine"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/enowdivine/stateledger.git"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "dev": "pnpm -r --filter \"./packages/**\" --parallel dev",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "pnpm -r --filter \"./packages/**\" typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "clean": "pnpm -r --filter \"./packages/**\" clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
