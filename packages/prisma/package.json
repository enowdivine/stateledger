{
  "name": "@stateledger/prisma",
  "version": "0.0.1-experimental.0",
  "description": "Prisma + Postgres adapter for stateledger — persisted, audited, concurrency-safe state machines.",
  "license": "MIT",
  "author": "Enow Divine",
  "repository": {
    "type": "git",
    "url": "https://github.com/enowdivine/stateledger.git",
    "directory": "packages/prisma"
  },
  "homepage": "https://github.com/enowdivine/stateledger#readme",
  "bugs": {
    "url": "https://github.com/enowdivine/stateledger/issues"
  },
  "keywords": [
    "state-machine",
    "prisma",
    "postgres",
    "stateledger",
    "audit-trail",
    "fsm"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --exclude '**/postgres.contract.test.ts'",
    "test:integration": "vitest run test/postgres.contract.test.ts",
    "prisma:generate": "STATELEDGER_TEST_DATABASE_URL=postgresql://placeholder prisma generate --schema test/prisma/schema.prisma",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@stateledger/core": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": ">=5"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "testcontainers": "^10.16.0"
  }
}
